<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">

  <!-- обов'язково GUID → x_integrix_external_id -->
  <record id="ixmap_id_guid" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">id</field>
    <field name="odoo_field">x_integrix_external_id</field>
  </record>

  <!-- name* → name -->
  <record id="ixmap_name" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">name</field>
    <field name="odoo_field">name</field>
  </record>

  <!-- parent_id* → parent_id -->
  <record id="ixmap_parent_id" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">parent_id</field>
    <field name="odoo_field">parent_id</field>
  </record>

  <!-- code/tag → serial_no -->
  <record id="ixmap_code_or_tag" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">code</field>
    <field name="odoo_field">serial_no</field>
  </record>

  <!-- category → category_id/asset_category_id -->
  <record id="ixmap_category" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">category</field>
    <field name="odoo_field">category_id</field>
  </record>

  <!-- site/location_path → location_id/complete_name  -->
  <record id="ixmap_location_path" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">site/location_path</field>
    <field name="odoo_field">location_id</field>
  </record>

  <!-- criticality → x_criticality -->
  <record id="ixmap_criticality" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">criticality</field>
    <field name="odoo_field">x_criticality</field>
  </record>

  <!-- status → equipment_state/active  -->
  <record id="ixmap_status" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">status</field>
    <field name="odoo_field">equipment_state</field>
  </record>

  <!-- manufacturer/model → x_manufacturer, x_model -->
  <record id="ixmap_manufacturer" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">manufacturer</field>
    <field name="odoo_field">x_manufacturer</field>
  </record>

  <record id="ixmap_model" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">model</field>
    <field name="odoo_field">x_model</field>
  </record>

  <!-- commissioning_date → date/acquisition_date  -->
  <record id="ixmap_commissioning_date" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">commissioning_date</field>
    <field name="odoo_field">acquisition_date</field>
  </record>

  <!-- serial_number → serial_no -->
  <record id="ixmap_serial_number" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">serial_number</field>
    <field name="odoo_field">serial_no</field>
  </record>

  <!-- uom → x_uom -->
  <record id="ixmap_uom" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">uom</field>
    <field name="odoo_field">x_uom</field>
  </record>

  <!-- cost_center → x_cost_center -->
  <record id="ixmap_cost_center" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">cost_center</field>
    <field name="odoo_field">x_cost_center</field>
  </record>

  <!-- notes → note -->
  <record id="ixmap_notes" model="integrix.field.map">
    <field name="active">True</field>
    <field name="ix_field">notes</field>
    <field name="odoo_field">note</field>
  </record>

</odoo>
