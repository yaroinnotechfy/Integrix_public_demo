<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Bulk Link -->
  <record id="action_equipment_bulk_link" model="ir.actions.server">
    <field name="name">Link to Integri-x</field>
    <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="state">code</field>
    <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="binding_type">action</field>
    <field name="code">
action = env['maintenance.equipment'].action_bulk_link()
result = action
    </field>
  </record>

  <!-- Bulk Sync -->
  <record id="action_equipment_bulk_sync" model="ir.actions.server">
    <field name="name">Sync to Integri-x</field>
    <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="state">code</field>
    <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="binding_type">action</field>
    <field name="code">
action = env['maintenance.equipment'].action_bulk_sync()
result = action
    </field>
  </record>

  <record id="action_equipment_bulk_unlink" model="ir.actions.server">
    <field name="name">Unlink from Integri-x</field>
    <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="state">code</field>
    <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="binding_type">action</field>
    <field name="code">
action = env['maintenance.equipment'].action_bulk_unlink()
result = action
    </field>
  </record>
</odoo>
