<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- STEP 1 -->
  <record id="view_integrix_setup_wizard_form_step1" model="ir.ui.view">
    <field name="name">integrix.setup.wizard.form.step1</field>
    <field name="model">integrix.setup.wizard</field>
    <field name="arch" type="xml">
      <form string="Integri-x Setup — Step 1/4: Connect" create="false" edit="true" delete="false">
        <sheet>
          <group>
            <group string="Connection">
              <field name="base_url"/>
              <field name="api_email"/>
              <field name="api_password" password="True"/>
              <field name="company_id"/>
              <field name="probe_path"/>
              <button name="action_test_connection_wizard" type="object" string="Test Connection" class="btn-primary"/>
            </group>
            <group string="Probe Result">
              <field name="ping_status" readonly="1"/>
              <field name="ping_tenant" readonly="1"/>
              <field name="ping_api_version" readonly="1"/>
            </group>
          </group>
        </sheet>
        <footer>
          <button name="action_next" type="object" string="Next" class="btn-primary oe_highlight"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- STEP 2 -->
  <record id="view_integrix_setup_wizard_form_step2" model="ir.ui.view">
    <field name="name">integrix.setup.wizard.form.step2</field>
    <field name="model">integrix.setup.wizard</field>
    <field name="arch" type="xml">
      <form string="Integri-x Setup — Step 2/4: Sync Policy" create="false" edit="true" delete="false">
        <sheet>
          <group>
            <group string="SSOT"><field name="ssot"/></group>
            <group string="Sync Direction"><field name="sync_direction"/></group>
          </group>
        </sheet>
        <footer>
          <button name="action_back" type="object" string="Back" class="btn-secondary"/>
          <button name="action_next" type="object" string="Next" class="btn-primary oe_highlight"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- STEP 3 -->
  <record id="view_integrix_setup_wizard_form_step3" model="ir.ui.view">
    <field name="name">integrix.setup.wizard.form.step3</field>
    <field name="model">integrix.setup.wizard</field>
    <field name="arch" type="xml">
      <form string="Integri-x Setup — Step 3/4: Field Mapping" create="false" edit="true" delete="false">
        <sheet>
          <group class="o_inner_group o_col-12">
            <field name="line_ids" widget="one2many_list" context="{'default_wizard_id': active_id}" editable="bottom" class="ix-map-list" options="{'no_open': True}">
              <tree><!-- вузька колонка активності -->
    <field name="active" widget="boolean_toggle" string="Active" class="w-10"/>
    <!-- поле з боку Integri-x -->
    <field name="ix_field" string="Integrix" class="w-40"/>
    <!-- цільове поле в Odoo -->
    <field name="odoo_field" string="Odoo Field" class="w-50"/></tree>
              <form string="Mapping line">
                <group>
                  <field name="active"/>
                  <field name="sequence"/>
                  <field name="ix_field"/>
                  <field name="odoo_field"/>
                </group>
              </form>
            </field>
          </group>
        </sheet>
        <footer>
          <button name="action_back" type="object" string="Back" class="btn-secondary"/>
          <button name="action_next" type="object" string="Next" class="btn-primary oe_highlight"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- STEP 4 (як працювало: кнопка-нотифікація + Finish) -->
  <record id="view_integrix_setup_wizard_form_step4" model="ir.ui.view">
    <field name="name">integrix.setup.wizard.form.step4</field>
    <field name="model">integrix.setup.wizard</field>
    <field name="arch" type="xml">
      <form string="Integri-x Setup — Step 4/4: Initial Sync" create="false" edit="true" delete="false">
        <sheet>
          <group>
            <separator string="You can run initial sync after saving settings."/>
            <button name="action_initial_sync_demo" type="object" string="Run Initial Sync (demo)" class="btn-secondary"/>
          </group>
        </sheet>
        <footer>
          <button name="action_back" type="object" string="Back" class="btn-secondary"/>
          <button name="action_finish" type="object" string="Finish" class="btn-primary oe_highlight"/>
        </footer>
      </form>
    </field>
  </record>

  <!-- ACTION -->
  <record id="action_integrix_setup_wizard" model="ir.actions.act_window">
    <field name="name">Integri-x Setup Wizard</field>
    <field name="res_model">integrix.setup.wizard</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="view_integrix_setup_wizard_form_step1"/>
    <field name="target">new</field>
    <field name="context">{}</field>
  </record>

</odoo>
