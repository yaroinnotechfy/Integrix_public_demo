<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- ROOT app menu -->
  <record id="menu_integrix_root" model="ir.ui.menu">
    <field name="name">Integri-x Sync</field>
    <field name="sequence">40</field>
    <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    <field name="web_icon">integrix_connector,static/description/icon_v2.png</field>
    <field name="action" ref="action_integrix_dashboard"/>
  </record>

  <!-- Dashboard -->
  <record id="menu_integrix_dashboard" model="ir.ui.menu">
    <field name="name">Dashboard</field>
    <field name="parent_id" ref="menu_integrix_root"/>
    <field name="sequence">1</field>
    <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
    <field name="action" ref="action_integrix_dashboard"/>
  </record>

  <!-- Setup Wizard -->
  <record id="menu_integrix_setup_wizard" model="ir.ui.menu">
    <field name="name">Setup Wizard</field>
    <field name="parent_id" ref="menu_integrix_root"/>
    <field name="sequence">2</field>
    <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
  </record>

  <!-- Settings  -->
  <record id="menu_integrix_settings" model="ir.ui.menu">
    <field name="name">Settings</field>
    <field name="parent_id" ref="menu_integrix_root"/>
    <field name="sequence">3</field>
    <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
    <field name="action" ref="action_integrix_config"/>
  </record>
</odoo>
