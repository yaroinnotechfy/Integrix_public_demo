<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_equipment_form_inherit_integrix" model="ir.ui.view">
    <field name="name">maintenance.equipment.form.integrix</field>
    <field name="model">maintenance.equipment</field>
    <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
    <field name="arch" type="xml">

      <!-- button box -->
      <xpath expr="//div[@name='button_box']" position="inside">
        <!-- Неклікабельний бейдж "Linked" -->
        <div class="oe_stat_button ix-linked-badge text-success"
             style="margin-left:12px; vertical-align:middle;"
             invisible="not x_integrix_external_id">
          <i class="fa fa-link o_stat_icon" style="margin-right:6px;"/>
          <span class="o_stat_text">Linked</span>
        </div>

        <!-- Link видно, коли external_id порожній -->
        <button type="object" name="action_link_integrix" class="btn btn-secondary"
                string="Link to Integri-x"
                invisible="x_integrix_external_id"/>

        <!-- Sync / Open / Unlink видно, коли external_id заповнений -->
        <button type="object" name="action_sync_integrix" class="btn btn-primary"
                string="Sync"
                invisible="not x_integrix_external_id"/>
        <button type="object" name="action_open_integrix" class="btn btn-secondary"
                string="Open in Integri-x"
                invisible="not x_integrix_external_id"/>
        <button type="object" name="action_unlink_integrix" class="btn btn-secondary"
                string="Unlink from Integri-x"
                invisible="not x_integrix_external_id"/>
      </xpath>

      <!-- вкладка з полями -->
      <xpath expr="//sheet/notebook" position="inside">
        <page string="Integri-x">
          <group>
            <group>
              <field name="x_integrix_external_id"/>
              <field name="x_criticality"/>
              <field name="x_manufacturer"/>
              <field name="x_model"/>
            </group>
            <group>
              <field name="x_uom"/>
              <field name="x_cost_center"/>
            </group>
          </group>
        </page>
      </xpath>

    </field>
  </record>
</odoo>
