<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_equipment_tree_inherit_integrix_flags" model="ir.ui.view">
    <field name="name">maintenance.equipment.tree.integrix.flags</field>
    <field name="model">maintenance.equipment</field>
    <field name="inherit_id" ref="maintenance.hr_equipment_view_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//tree/field[@name='serial_no']" position="after">
        <field name="x_is_linked" string="Linked" widget="boolean_button" readonly="1"/>
      </xpath>
    </field>
  </record>

  <record id="view_equipment_search_inherit_integrix_flags" model="ir.ui.view">
    <field name="name">maintenance.equipment.search.integrix.flags</field>
    <field name="model">maintenance.equipment</field>
    <field name="inherit_id" ref="maintenance.hr_equipment_view_search"/>
    <field name="arch" type="xml">
      <xpath expr="//search" position="inside">
        <filter string="Linked" name="ix_linked"
                domain="[('x_is_linked','=',True)]"/>
        <filter string="Not linked" name="ix_not_linked"
                domain="[('x_is_linked','=',False)]"/>
      </xpath>
    </field>
  </record>
</odoo>
