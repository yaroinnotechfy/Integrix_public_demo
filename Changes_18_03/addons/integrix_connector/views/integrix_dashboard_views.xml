<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="action_integrix_dashboard" model="ir.actions.act_window">
    <field name="name">Integri-x Sync Dashboard</field>
    <field name="res_model">integrix.dashboard</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
    <field name="res_id" ref="integrix_connector.integrix_dashboard_singleton"/>
  </record>

  <record id="view_integrix_dashboard_form" model="ir.ui.view">
    <field name="name">integrix.dashboard.form</field>
    <field name="model">integrix.dashboard</field>
    <field name="arch" type="xml">
      <form string="Integri-x Sync" create="false" edit="false" delete="false">
        <sheet>
          <group col="2">

            <!-- LEFT: CONNECTION -->
            <group string="CONNECTION" class="o_inner_group o_col-9">
              <group col="6" class="o_inner_group">
                <label for="base_url" string="Base Url"/>
                <field name="base_url" nolabel="1" readonly="1" colspan="5" class="ix-wide ix-nowrap"/>

                <label for="api_version" string="Api Version"/>
                <field name="api_version" nolabel="1" readonly="1" colspan="5" class="ix-wide ix-nowrap"/>

                <label for="tenant" string="Tenant"/>
                <field name="tenant" nolabel="1" readonly="1" colspan="5" class="ix-wide ix-nowrap"/>
              </group>

              <!-- buttons row (flex, адаптивний) -->
              <div class="o_row mt-2 ix-btnbar">
                <button type="object" name="action_open_settings"
                        string="Open Settings" class="btn btn-secondary ix-btn"/>
                <button name="action_open_wizard" type="object"
                        string="Run Setup Wizard" class="btn btn-primary ix-btn"/>
              </div>
            </group>

            <!-- RIGHT: SYNCHRONIZATION -->
            <group string="SYNCHRONIZATION" class="o_inner_group o_col-3">
              <group col="2" class="o_inner_group">
                <label for="last_sync" string="Last Sync"/>
                <field name="last_sync" nolabel="1" readonly="1"/>
              </group>
            </group>

          </group>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
