<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Server Action + binding у списку -->
  <record id="action_equipment_import_from_ix" model="ir.actions.server">
    <field name="name">Import from Integri-x</field>
    <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="state">code</field>
    <field name="binding_model_id" ref="maintenance.model_maintenance_equipment"/>
    <field name="binding_type">action</field>
    <field name="code">
action = env['maintenance.equipment'].action_import_from_integrix()
result = action
    </field>
  </record>

  <!-- Крон: щогодини -->
  <record id="ir_cron_integrix_hourly_import" model="ir.cron">
    <field name="name">Integri-x Hourly Import</field>
    <field name="model_id" ref="base.model_ir_actions_server"/>
    <field name="state">code</field>
    <field name="code">env['integrix.sync'].run_import_once()</field>
    <field name="interval_type">hours</field>
    <field name="interval_number">1</field>
    <field name="numbercall">-1</field>
    <field name="active">False</field>
  </record>
</odoo>
