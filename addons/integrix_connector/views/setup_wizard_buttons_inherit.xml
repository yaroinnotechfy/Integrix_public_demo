      <field name="arch" type="xml">
        <xpath expr="//button[@name='action_test_connection_wizard']" position="attributes">
          <attribute name="style">min-width:360px; white-space:nowrap; display:inline-block;</attribute>
        </xpath>
      </field>
    </record>

    <!-- Step 4: -->
  </data>
</odoo>
